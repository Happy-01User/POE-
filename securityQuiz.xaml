<Window x:Class="lemo3.securityQuiz"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lemo3"
        mc:Ignorable="d" 
        Title="Cyber Security Quiz"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====================== -->
        <!-- TOP NAVIGATION BAR -->
        <!-- ====================== -->

        <Border Grid.Row="0"
                Background="#1F2937"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,15">

            <DockPanel>

                <TextBlock Text="LEMO CYBER SECURITY"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="ChatBtn"
                            Content="Chat"
                            Width="110"
                            Height="35"
                            Margin="10,0"
                            Click="ChatBtn_Click"/>

                    <Button x:Name="TaskBtn"
                            Content="Tasks"
                            Width="110"
                            Height="35"
                            Margin="10,0"
                            Click="TaskBtn_Click"/>

                    <Button x:Name="ActivityBtn"
                            Content="Activity"
                            Width="110"
                            Height="35"
                            Margin="10,0"
                            Click="ActivityBtn_Click"/>

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- ====================== -->
        <!-- QUIZ HEADER -->
        <!-- ====================== -->

        <Border Grid.Row="1"
                Background="#2563EB"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">

            <TextBlock Text="Cybersecurity Knowledge Quiz"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

        </Border>

        <!-- ====================== -->
        <!-- QUIZ CONTENT -->
        <!-- ====================== -->

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <TextBlock x:Name="txtQuestion"
                           FontSize="22"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,25"/>

                <RadioButton x:Name="rbA"
                             FontSize="17"
                             Margin="0,8"
                             GroupName="Answers"/>

                <RadioButton x:Name="rbB"
                             FontSize="17"
                             Margin="0,8"
                             GroupName="Answers"/>

                <RadioButton x:Name="rbC"
                             FontSize="17"
                             Margin="0,8"
                             GroupName="Answers"/>

                <RadioButton x:Name="rbD"
                             FontSize="17"
                             Margin="0,8"
                             GroupName="Answers"/>

                <TextBlock x:Name="txtScore"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="DarkBlue"
                           Margin="0,30,0,0"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

        <!-- ====================== -->
        <!-- BOTTOM BUTTON -->
        <!-- ====================== -->

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <!--      <Button Name="btnNext"
                    Content="Next Question"
                    Width="170"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Click="btnNext_Click"/>-->
            <Button x:Name="btnNext"
                    Content="Next Question"
                    Width="170"
                    Height="45"
                    FontSize="16" Click="btnNext_Click"
                    />

        </StackPanel>

    </Grid>

</Window>